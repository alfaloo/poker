      "definition": "select \"users\".\"username\", \"users\".\"balance\" + COALESCE(\"game_sessions\".\"session_stack\", 0) as \"total_balance\" from \"users\" left join \"game_sessions\" on \"game_sessions\".\"user_id\" = \"users\".\"id\" order by total_balance DESC limit 10",
